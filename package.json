{
  "name": "agent-threads",
  "version": "0.1.0",
  "description": "Read-only local CLI for searching and reading agent session history",
  "private": true,
  "type": "module",
  "bin": {
    "ath": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src test --error-on-warnings",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/sql": "^0.51.0",
    "@effect/sql-sqlite-bun": "^0.52.0",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/bun": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
